// https://opencode.ai/docs/config
{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
      // https://github.com/ChromeDevTools/chrome-devtools-mcp
      "chrome-devtools": {
        "type": "local",
        "command": [
          "npx",
          "-y",
          "chrome-devtools-mcp@latest"
        ],
        "enabled": false
      },
    // https://github.com/upstash/context7
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    // https://docs.exa.ai/reference/exa-mcp
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}"
      },
      "enabled": true
    },
    // https://vercel.com/blog/grep-a-million-github-repositories-via-mcp
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    // https://github.com/chrisdoc/hevy-mcp
    "hevy": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "hevy-mcp@latest"
      ],
      "environment": {
        "HEVY_API_KEY": "{env:HEVY_API_KEY}"
      },
      "enabled": false
    },
    // https://docs.incident.io/ai/remote-mcp
    "incidentio-work": {
      "type": "remote",
      "url": "https://mcp.incident.io/mcp",
      "enabled": false
    },
    // https://linear.app/docs/mcp
    "linear-work": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": false
    },
    // https://developers.notion.com/guides/mcp/get-started-with-mcp
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false
    },
    "notion-work": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false
    },
    // https://github.com/microsoft/playwright-mcp
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    // https://docs.sentry.io/product/sentry-mcp
    "sentry-work": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": false
    }
  },
  // https://models.dev
  "model": "anthropic/claude-opus-4-8",
  "small_model": "anthropic/claude-haiku-4-5",
  // Default-allow with ask/deny on irreversible or public actions.
  // Last matching rule wins: broad rules first, narrow rules last.
  // In-project changes are recoverable via git + per-message snapshots (/undo).
  // Anything touching paths outside the project still prompts via external_directory.
  "permission": {
    "bash": {
      "*": "allow",
      // never
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      // local but destructive -> ask
      "rm -rf ~*": "ask",
      "git reset --hard*": "ask",
      "brew install*": "ask",
      "brew uninstall*": "ask",
      // public or irreversible -> ask (AGENTS.md: no public actions unasked)
      "git push*": "ask",
      "gh pr create*": "ask",
      "gh pr merge*": "ask",
      "gh pr close*": "ask",
      "gh pr comment*": "ask",
      "gh pr review*": "ask",
      "gh issue create*": "ask",
      "gh issue comment*": "ask",
      "gh issue close*": "ask",
      "gh release create*": "ask",
      "gh repo create*": "ask",
      "gh repo delete*": "ask",
      "gh gist create*": "ask",
      "npm publish*": "ask",
      "pnpm publish*": "ask",
      "yarn publish*": "ask",
      "bun publish*": "ask",
      "deno publish*": "ask",
      "docker push*": "ask"
    },
    "external_directory": {
      "*": "ask",
      "~/Developer/repos/**": "allow",
      "~/Developer/worktrees/**": "allow",
      "/tmp/**": "allow",
      "/private/tmp/**": "allow",
      "/var/folders/**": "allow",
      "/private/var/folders/**": "allow"
    }
  },
  "plugin": [
    // https://github.com/franlol/opencode-md-table-formatter
    "@franlol/opencode-md-table-formatter@latest",
    // https://github.com/griffinmartin/opencode-claude-auth
    "opencode-claude-auth@latest",
    // https://github.com/backnotprop/plannotator
    "@plannotator/opencode@latest"
  ],
  "share": "disabled"
}
