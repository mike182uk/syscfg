{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "autoMemoryEnabled": false,
  "cleanupPeriodDays": 20,
  "effortLevel": "high",
  "feedbackSurveyRate": 0,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/mike/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "mcp__context7",
      "mcp__exa",
      "mcp__grep"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard:*)",
      "Bash(gh pr create)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh issue create)",
      "Bash(gh issue create:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue close:*)",
      "Bash(gh release create:*)",
      "Bash(gh repo create)",
      "Bash(gh repo create:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh gist create:*)",
      "Bash(npm publish)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish)",
      "Bash(pnpm publish:*)",
      "Bash(yarn publish)",
      "Bash(yarn publish:*)",
      "Bash(bun publish)",
      "Bash(bun publish:*)",
      "Bash(deno publish)",
      "Bash(deno publish:*)",
      "Bash(docker push:*)",
      "Bash(brew install:*)",
      "Bash(brew uninstall:*)"
    ],
    "defaultMode": "auto",
    "deny": [
      "Bash(sudo:*)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  },
  "plansDirectory": "./.plans",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "padding": 0,
    "type": "command"
  },
  "theme": "dark-ansi"
}