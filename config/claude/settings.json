{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 20,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "mcp__context7",
      "mcp__exa",
      "mcp__grep"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard:*)",
      "Bash(gh pr create)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh issue create)",
      "Bash(gh issue create:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue close:*)",
      "Bash(gh release create:*)",
      "Bash(gh repo create)",
      "Bash(gh repo create:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh gist create:*)",
      "Bash(npm publish)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish)",
      "Bash(pnpm publish:*)",
      "Bash(yarn publish)",
      "Bash(yarn publish:*)",
      "Bash(bun publish)",
      "Bash(bun publish:*)",
      "Bash(deno publish)",
      "Bash(deno publish:*)",
      "Bash(docker push:*)",
      "Bash(brew install:*)",
      "Bash(brew uninstall:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "feedbackSurveyRate": 0,
  "effortLevel": "high",
  "plansDirectory": "./.plans",
  "autoMemoryEnabled": false,
  "theme": "dark-ansi",
  "skipDangerousModePermissionPrompt": true
}
