{
  "catalogLens.enabled": true,
  "cursor-retrieval.canAttemptGithubLogin": false,
  "cursor.composer.usageSummaryDisplay": "always",
  "cursor.cpp.disabledLanguages":
  [
      "scminput"
  ],
  "cursor.cpp.enablePartialAccepts": true,
  "cursor.preferNotificationsSameAsChat": true,
  "cursor.windowSwitcher.sidebarHoverCollapsed": true,
  "deno.enable": false,
  "editor.accessibilitySupport": "off",
  "editor.fontFamily": "Jetbrains Mono",
  "editor.fontSize": 14,
  "editor.lineHeight": 42,
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "all",
  "editor.rulers":
  [
      80
  ],
  "editor.semanticHighlighting.enabled": true,
  "git.blame.editorDecoration.enabled": true,
  "git.blame.statusBarItem.enabled": true,
  "go.toolsGopath": "~/.vscode/go-tools",
  "go.toolsManagement.autoUpdate": true,
  "gopls":
  {
      "ui.semanticTokens": true
  },
  "javascript.updateImportsOnFileMove.enabled": "always",
  "markdown.extension.toc.updateOnSave": false,
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
  "redhat.telemetry.enabled": false,
  "terminal.integrated.minimumContrastRatio": 1,
  "workbench.colorCustomizations":
  {
      "git.blame.editorDecorationForeground": "#565f89"
  },
  "workbench.colorTheme": "Tokyo Night",
  "workbench.tree.indent": 22,
  "workbench.tree.renderIndentGuides": "always"
}
